############################################################
# DATABASE LAB ENVIRONMENT TEMPLATE
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Replace placeholder values with your own passwords.
#
# 3. Do NOT commit your .env file to GitHub.
############################################################


############################################################
# MySQL Configuration
############################################################

MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password
MYSQL_DATABASE=labdb
MYSQL_USER=labuser
MYSQL_PASSWORD=replace_with_mysql_user_password


############################################################
# PostgreSQL Configuration
############################################################

POSTGRES_USER=labuser
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_DB=labdb


############################################################
# Oracle Database Free (23c)
############################################################

# This sets the SYS and SYSTEM password
ORACLE_PASSWORD=replace_with_oracle_password


############################################################
# Optional - Port Customization (Uncomment if needed)
# Use these only if default ports conflict with
# a local installation on your machine.
############################################################

# MYSQL_PORT=3306
# POSTGRES_PORT=5432
# ORACLE_PORT=1521
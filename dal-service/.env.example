# API key for service-to-service authentication (required)
API_KEY=dev-api-key-change-in-production

# Set to true to auto-create tables on startup (classroom demo only; use migrations in production)
INIT_SCHEMA=true

# Set to true to seed library data on first run (1000 students, 2000 books, 30k loans)
# Only runs when database is empty; skips if already seeded
SEED_LIBRARY_DATA=true

# === PostgreSQL (profile: postgres) ===
DB_VENDOR=postgres
DB_HOST=db_postgres
DB_PORT=5432
DB_NAME=cs4332
DB_USER=cs4332
DB_PASSWORD=cs4332pass

# === MySQL (profile: mysql) - uncomment and change when using mysql profile ===
# DB_VENDOR=mysql
# DB_HOST=db_mysql
# DB_PORT=3306
# DB_NAME=cs4332
# DB_USER=cs4332
# DB_PASSWORD=cs4332pass
# MYSQL_ROOT_PASSWORD=rootpass

Table employees {
  employee_id int [pk, increment]
  name varchar
  email varchar [unique]
}

Table projects {
  project_id int [pk, increment]
  name varchar
}

Table assignments {
  employee_id int [not null]
  project_id int [not null]
  start_date date [not null]
  end_date date
  role varchar
  allocation_percent int

  Indexes {
    (employee_id, project_id, start_date) [pk]
  }
}

Ref: assignments.employee_id > employees.employee_id
Ref: assignments.project_id > projects.project_id
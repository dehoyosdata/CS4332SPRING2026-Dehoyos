// ===================================================
// EXAMPLE C (10 tables): HOSPITAL CARE + BILLING
// Goal: Showcase weak-entity-like composite keys (visit procedures),
//       multiple relationship tables, and optionality patterns.
// ===================================================

// ---------- CORE ENTITIES ----------
Table patients {
  patient_id int [pk, increment]
  name varchar
  dob date
  phone varchar
}

Table doctors {
  doctor_id int [pk, increment]
  name varchar
  specialty varchar
}

Table departments {
  department_id int [pk, increment]
  name varchar [unique]
}

Table rooms {
  room_id int [pk, increment]
  department_id int [not null]
  room_number varchar
  room_type varchar                 // ICU/ER/GENERAL
}

// ---------- CARE EPISODE ----------
Table visits {
  visit_id int [pk, increment]
  patient_id int [not null]         // patient has many visits (1:N)
  attending_doctor_id int [not null]// one main doctor per visit (can add more via consults)
  admitted_at timestamp
  discharged_at timestamp
  reason varchar
}

// ---------- CONSULTS (M:N doctor-visit) ----------
Table consults {
  visit_id int [not null]
  doctor_id int [not null]
  consult_reason varchar
  consulted_at timestamp

  Indexes {
    (visit_id, doctor_id) [pk]
  }
}

// ---------- PROCEDURES CATALOG ----------
Table procedures {
  procedure_code varchar [pk]       // stable code (e.g., CPT-like)
  name varchar
  base_cost decimal
}

// ---------- VISIT PROCEDURES (weak-entity-like pattern) ----------
Table visit_procedures {
  // Think of this as a "weak entity" dependent on visits:
  // it cannot exist without visit_id, and is uniquely identified within a visit by line_no.
  visit_id int [not null]
  line_no int [not null]            // partial key within a visit
  procedure_code varchar [not null]
  performed_by_doctor_id int [not null]
  performed_at timestamp
  units int [not null]

  Indexes {
    (visit_id, line_no) [pk]        // composite PK = (owner key + partial key)
  }
}

// ---------- MEDICATIONS (M:N visit-medication with attributes) ----------
Table medications {
  med_id int [pk, increment]
  name varchar
  form varchar                      // tablet/injection
}

Table prescriptions {
  visit_id int [not null]
  med_id int [not null]
  dose varchar
  frequency varchar
  start_date date
  end_date date

  Indexes {
    (visit_id, med_id, start_date) [pk] // allows same med prescribed again later
  }
}

// ---------- BILLING ----------
Table invoices {
  invoice_id int [pk, increment]
  visit_id int [not null]           // one visit may have one invoice (often 1:1), modeled as 1:N for flexibility
  issued_at timestamp
  status varchar                    // DRAFT/SENT/PAID
  total_amount decimal
}

// ---------- RELATIONSHIPS ----------
Ref: rooms.department_id > departments.department_id
Ref: visits.patient_id > patients.patient_id
Ref: visits.attending_doctor_id > doctors.doctor_id
Ref: consults.visit_id > visits.visit_id
Ref: consults.doctor_id > doctors.doctor_id
Ref: visit_procedures.visit_id > visits.visit_id
Ref: visit_procedures.procedure_code > procedures.procedure_code
Ref: visit_procedures.performed_by_doctor_id > doctors.doctor_id
Ref: prescriptions.visit_id > visits.visit_id
Ref: prescriptions.med_id > medications.med_id
Ref: invoices.visit_id > visits.visit_id
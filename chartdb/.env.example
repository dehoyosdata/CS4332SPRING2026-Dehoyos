# ChartDB Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Optional: OpenAI API key for AI-powered schema export (e.g., DDL conversion between dialects)
# Get your key at https://platform.openai.com/api-keys
# Leave empty to run without AI features
OPENAI_API_KEY=

# Optional: Set to "true" to disable Fathom Analytics (default: true)
DISABLE_ANALYTICS=true
